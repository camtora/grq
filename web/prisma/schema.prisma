generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// All money values are integer cents (CAD unless noted). All quantities are
// whole shares — fractional shares are not in the v1 universe.

enum RiskLevel {
  CAUTIOUS
  BALANCED
  AGGRESSIVE
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
}

enum OrderStatus {
  PENDING
  FILLED
  CANCELLED
  REJECTED
}

enum JournalKind {
  SYSTEM
  RESEARCH
  DECISION
  TRADE
  RETRO
  LESSON
}

enum ReportKind {
  EOD
  WEEKLY
}

model Account {
  id        Int      @id @default(1)
  cashCents Int      @default(0)
  updatedAt DateTime @updatedAt
}

model Settings {
  id                  Int       @id @default(1)
  riskLevel           RiskLevel @default(BALANCED)
  feeBudgetCentsMonth Int       @default(2000)
  killSwitch          Boolean   @default(false)
  killSwitchBy        String?
  killSwitchAt        DateTime?
  agentVersion        String    @default("v1.0-phase2")
  updatedBy           String?
  updatedAt           DateTime  @updatedAt
}

model Contribution {
  id            Int      @id @default(autoincrement())
  at            DateTime @default(now())
  amountCents   Int
  // Who put this money in ("Cam" | "Graham"). Ownership is data, not code —
  // the app supports single-owner, joint (CRA: gains allocate by contribution
  // proportion), or future multi-account. See docs/OWNERSHIP.md.
  contributor   String?
  // XIC mid price when the money arrived — anchors the "vs just buying XIC" benchmark.
  xicPriceCents Int?
  note          String?
}

model Order {
  id                Int            @id @default(autoincrement())
  createdAt         DateTime       @default(now())
  symbol            String
  side              OrderSide
  type              OrderType
  qty               Int
  limitPriceCents   Int?
  status            OrderStatus    @default(PENDING)
  filledQty         Int            @default(0)
  avgFillPriceCents Int?
  commissionCents   Int            @default(0)
  placedBy          String
  reason            String?
  rejectReason      String?
  broker            String         @default("sim")
  trades            Trade[]
  journal           JournalEntry[]

  @@index([createdAt])
  @@index([status])
}

model Trade {
  id               Int       @id @default(autoincrement())
  orderId          Int
  order            Order     @relation(fields: [orderId], references: [id])
  at               DateTime  @default(now())
  symbol           String
  side             OrderSide
  qty              Int
  priceCents       Int
  commissionCents  Int
  realizedPnlCents Int?

  @@index([at])
}

model Position {
  symbol       String   @id
  qty          Int
  avgCostCents Int
  openedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NavSnapshot {
  id             Int      @id @default(autoincrement())
  at             DateTime @default(now())
  navCents       Int
  cashCents      Int
  positionsCents Int
  // What the same contributions would be worth in XIC (null if unknowable).
  benchmarkCents Int?
  note           String?

  @@index([at])
}

model JournalEntry {
  id           Int         @id @default(autoincrement())
  at           DateTime    @default(now())
  kind         JournalKind
  symbol       String?
  title        String
  body         String
  confidence   Int?
  // JSON array of source strings that fed this entry (attribution — D13).
  sourcesJson  String?
  agentVersion String      @default("v1.0-phase2")
  orderId      Int?
  order        Order?      @relation(fields: [orderId], references: [id])

  @@index([at])
  @@index([kind])
}

model Report {
  id        Int        @id @default(autoincrement())
  date      DateTime
  kind      ReportKind
  title     String
  body      String
  statsJson String?
  createdAt DateTime   @default(now())

  @@unique([date, kind])
}

// Daily OHLCV history — feeds the signals layer (2.5d) and the stock-page
// sparklines. Backfilled 1y, then maintained nightly after close.
model Bar {
  symbol     String
  date       DateTime
  openCents  Int
  highCents  Int
  lowCents   Int
  closeCents Int
  volume     Int

  @@id([symbol, date])
  @@index([symbol, date])
}

// Latest delayed quote per symbol. The agent's tick loop keeps these warm;
// web reads them (with on-demand fallback fetch) so request paths stay fast.
model Quote {
  symbol       String   @id
  bidCents     Int
  askCents     Int
  midCents     Int
  dayChangeBps Int      @default(0)
  at           DateTime
  source       String   @default("yahoo-delayed")
}

model Watchlist {
  symbol  String   @id
  note    String?
  addedAt DateTime @default(now())
}

// Agent heartbeat — read by /api/health and the dashboard.
model AgentState {
  id            Int       @id @default(1)
  bootAt        DateTime?
  lastTickAt    DateTime?
  lastSessionAt DateTime?
  note          String?
  updatedAt     DateTime  @updatedAt
}
