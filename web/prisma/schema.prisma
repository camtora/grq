generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// All money values are integer cents (CAD unless noted). All quantities are
// whole shares — fractional shares are not in the v1 universe.

enum RiskLevel {
  CAUTIOUS
  BALANCED
  AGGRESSIVE
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
}

enum OrderStatus {
  PENDING
  FILLED
  CANCELLED
  REJECTED
}

enum JournalKind {
  SYSTEM
  RESEARCH
  DECISION
  TRADE
  RETRO
  LESSON
  NOTE // a human note added on a stock page ("The record")
}

enum ReportKind {
  EOD
  WEEKLY
}

model Account {
  id        Int      @id @default(1)
  // CAD cash. USD cash is held separately (multi-currency — IBKR holds both, D33);
  // NAV converts USD→CAD at the BoC rate. Other currencies would warrant a table.
  cashCents    Int @default(0)
  usdCashCents Int @default(0)
  updatedAt DateTime @updatedAt
}

model Settings {
  id                  Int       @id @default(1)
  riskLevel           RiskLevel @default(BALANCED)
  feeBudgetCentsMonth Int       @default(2000)
  killSwitch          Boolean   @default(false)
  killSwitchBy        String?
  killSwitchAt        DateTime?
  agentVersion        String    @default("v1.0-phase2")
  updatedBy           String?
  updatedAt           DateTime  @updatedAt
}

model Contribution {
  id            Int      @id @default(autoincrement())
  at            DateTime @default(now())
  amountCents   Int
  // Who put this money in ("Cam" | "Graham"). Ownership is data, not code —
  // the app supports single-owner, joint (CRA: gains allocate by contribution
  // proportion), or future multi-account. See docs/OWNERSHIP.md.
  contributor   String?
  // XIC mid price when the money arrived — anchors the "vs just buying XIC" benchmark.
  xicPriceCents Int?
  note          String?
}

model Order {
  id                Int            @id @default(autoincrement())
  createdAt         DateTime       @default(now())
  symbol            String
  side              OrderSide
  type              OrderType
  qty               Int
  limitPriceCents   Int?
  status            OrderStatus    @default(PENDING)
  filledQty         Int            @default(0)
  avgFillPriceCents Int?
  commissionCents   Int            @default(0)
  placedBy          String
  reason            String?
  rejectReason      String?
  broker            String         @default("sim")
  // Broker-side order id (IBKR). Stored when an order is left PENDING (its fill
  // landed after our synchronous poll window) so the per-tick finaliser can resolve
  // it to a fill and write the Trade/journal — keeps the ledger from silently
  // missing slow fills. Null for sim orders and legacy rows.
  brokerOrderId     String?
  trades            Trade[]
  journal           JournalEntry[]

  @@index([createdAt])
  @@index([status])
}

model Trade {
  id               Int       @id @default(autoincrement())
  orderId          Int
  order            Order     @relation(fields: [orderId], references: [id])
  at               DateTime  @default(now())
  symbol           String
  side             OrderSide
  qty              Int
  priceCents       Int
  commissionCents  Int
  realizedPnlCents Int?

  @@index([at])
}

model Position {
  symbol       String   @id
  qty          Int
  avgCostCents Int
  // Native currency of avgCostCents + this name's quotes ("CAD" | "USD"). NAV/sizing
  // convert USD→CAD at the BoC rate (D33). Defaults CAD so existing rows are unchanged.
  currency     String   @default("CAD")
  openedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NavSnapshot {
  id             Int      @id @default(autoincrement())
  at             DateTime @default(now())
  navCents       Int
  cashCents      Int
  positionsCents Int
  // What the same contributions would be worth in XIC (null if unknowable).
  benchmarkCents Int?
  note           String?

  @@index([at])
}

model JournalEntry {
  id           Int         @id @default(autoincrement())
  at           DateTime    @default(now())
  kind         JournalKind
  symbol       String?
  title        String
  body         String
  confidence   Int?
  // JSON array of source strings that fed this entry (attribution — D13).
  sourcesJson  String?
  // Dossier price targets (Phase 1 "expected return"): a near-term swing target
  // (+ horizon in trading days) and a 12-month target, both in cents. These power
  // the expected-return figures on the Today page's "On the Radar".
  targetNearCents Int?
  targetNearDays  Int?
  targetFarCents  Int?
  // Plain-English "why" — 3–5 palatable bullets a non-expert can read, explaining
  // the agent's read on the stock. Surfaced on the stock page's bottom-line card.
  bottomLine      String?
  // The agent's OWN call (its judgment), distinct from the deterministic signal
  // consensus (a technicals formula). One of BUY/ACCUMULATE/HOLD/WATCH/TRIM/AVOID/SELL.
  // Where this diverges from the signal read, that divergence is the point.
  stance          String?
  // How under-the-radar a hunt find is (D38): the agent's 1–5 read — 5 = a deep cut
  // almost nobody covers, 1 = a well-followed name. Surfaced as the obscurity badge
  // on The Hunt and used to sort obscure-first. Null for non-hunt entries.
  obscurity       Int?
  agentVersion String      @default("v1.0-phase2")
  orderId      Int?
  order        Order?      @relation(fields: [orderId], references: [id])

  @@index([at])
  @@index([kind])
}

model Report {
  id        Int        @id @default(autoincrement())
  date      DateTime
  kind      ReportKind
  title     String
  body      String
  statsJson String?
  createdAt DateTime   @default(now())

  @@unique([date, kind])
}

// Daily OHLCV history — feeds the signals layer (2.5d) and the stock-page
// sparklines. Backfilled 1y, then maintained nightly after close.
model Bar {
  symbol     String
  date       DateTime
  openCents  Int
  highCents  Int
  lowCents   Int
  closeCents Int
  volume     Int

  @@id([symbol, date])
  @@index([symbol, date])
}

// Latest delayed quote per symbol. The agent's tick loop keeps these warm;
// web reads them (with on-demand fallback fetch) so request paths stay fast.
model Quote {
  symbol       String   @id
  bidCents     Int
  askCents     Int
  midCents     Int
  dayChangeBps Int      @default(0)
  at           DateTime
  source       String   @default("yahoo-delayed")
}

// The agent's FOCUS list — its shortlist of ACTIVE universe names it's actively
// monitoring for an entry, with conditional trigger notes ("watching ABX for a
// $54 hold"). Distinct from the human watchlist, which is now CANDIDATE members
// (2.8). Set by the agent via set_focus (ACTIVE members only). Physical table
// kept as "Watchlist" via @@map so the rename is zero-migration; the model name
// is what code uses.
model AgentFocus {
  symbol  String   @id
  note    String?
  addedAt DateTime @default(now())

  @@map("Watchlist")
}

// The universe pipeline (2.7): CANDIDATE = researched, not tradeable;
// ACTIVE = the agent may buy it (promotion requires BOTH members + the
// automated screen); RETIRED = stop researching (history is never deleted).
enum UniverseStatus {
  CANDIDATE
  ACTIVE
  RETIRED
}

model UniverseMember {
  symbol               String         @id
  yahoo                String
  name                 String
  tier                 String? // etf | large | mid — set at promotion
  status               UniverseStatus @default(CANDIDATE)
  addedBy              String?
  addedAt              DateTime       @default(now())
  promotionRequestedBy String?
  promotionRequestedAt DateTime?
  proposedTier         String?
  note                 String?
  // Resolved company logo URL (favicon by domain; FMP logos later). Lifecycle:
  // null = not yet resolved, "" = resolved but none found, URL = use it.
  logoUrl              String?
  // Fundamentals from FMP (refreshed by the agent runner) — power the stock
  // filters (country / exchange / industry / cap) and per-name context.
  // marketCapM is millions in the listing's own currency; bucketing the cap for
  // filters makes the currency moot. fmpAt = last refresh (null = never).
  sector               String?
  industry             String?
  country              String?
  currency             String?
  exchange             String?
  marketCapM           Int?
  fmpAt                DateTime?
  updatedAt            DateTime       @updatedAt
}

// On-demand + rotation research queue — the agent runner processes it.
enum ResearchStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

model ResearchRequest {
  id          Int            @id @default(autoincrement())
  symbol      String
  requestedBy String
  status      ResearchStatus @default(QUEUED)
  at          DateTime       @default(now())
  completedAt DateTime?
  error       String?

  @@index([status])
  @@index([at])
}

// Member steering for the agent (2.6c): BLOCKED = agent may never buy it
// (sells always allowed); PINNED = always on the watchlist. Binds the agent
// only — members' manual orders are exempt.
enum DirectiveType {
  PINNED
  BLOCKED
}

model SymbolDirective {
  symbol    String        @id
  directive DirectiveType
  by        String
  note      String?
  at        DateTime      @default(now())
}

// Source scoreboard (2.6a): retros grade every source a resolved thesis cited.
// +1 pointed the right way, −1 misleading, 0 neutral. Signal families are
// sources too ("signal:rsi").
model SourceGrade {
  id        Int      @id @default(autoincrement())
  at        DateTime @default(now())
  source    String
  symbol    String?
  grade     Int
  note      String?
  journalId Int?

  @@index([source])
  @@index([symbol])
}

// Per-member chat threads with the agent (read-only tools — chat can never
// trade). `owner` is the member whose thread this belongs to (their email);
// `email` is the author (a member email, or "agent" for assistant turns). Cam
// and Graham each have their own thread and can toggle into the other's.
model ChatMessage {
  id      Int      @id @default(autoincrement())
  at      DateTime @default(now())
  owner   String   @default("") // the member whose thread this is (email)
  email   String // author: a member email, or "agent"
  role    String // "user" | "assistant"
  content String

  @@index([owner, at])
  @@index([at])
}

// Cached agent explanations of finance/investing concepts (the literacy pillar's
// "explain this" — docs/LITERACY.md). Keyed by the normalized term so the second
// reader to click "shell company" pays $0 and gets it instantly.
model Explainer {
  key  String   @id // normalized term (lowercase, trimmed)
  term String
  body String
  at   DateTime @default(now())
}

// Human research notes — Cam & Graham's own desk (the Research tab is for human
// research, distinct from the agent's auto-dossiers). Optionally tagged to a symbol.
model Note {
  id     Int      @id @default(autoincrement())
  at     DateTime @default(now())
  author String
  symbol String?
  body   String

  @@index([at])
}

// --- Smart Money (D27) -------------------------------------------------------
// What notable public portfolios are doing, surfaced as colour/leads (not trade
// instructions). EXTERNAL reference data, not fund money: dollar values are stored
// as REPORTED (USD from US filings), like IndexQuote keeps index levels as plain
// numbers — never the integer-CAD-cents rule, because we never trade off these
// directly. BigInt where a 13F's market value overflows Int32 (Berkshire ~$263B).
// Refreshed by the agent runner: congress + insider daily, 13F when a new filing
// date appears (quarterly, ~45-day lag). See docs/DATA-SOURCES.md tiers 4 & 5.

// One manager's 13F as of a quarter-end. Holdings hang off it.
model PortfolioSnapshot {
  id            Int                @id @default(autoincrement())
  cik           String
  holderName    String
  asOf          DateTime // 13F "date" — quarter-end
  filedAt       DateTime? // when the 13F was filed (the ~45-day lag is asOf→filedAt)
  totalValueUsd BigInt // marketValue
  holdingsCount Int
  securitiesAdded   Int? // new positions this quarter
  securitiesRemoved Int? // exited positions this quarter
  perf1yPct     Float? // trailing 1-yr portfolio performance (FMP holder-perf)
  fetchedAt     DateTime           @default(now())
  holdings      PortfolioHolding[]

  @@unique([cik, asOf])
  @@index([cik])
}

// One line of a 13F (a symbol can appear as common + PUT + CALL — kept distinct,
// matching the filing). action is derived by diffing against the prior quarter.
model PortfolioHolding {
  id           Int               @id @default(autoincrement())
  snapshotId   Int
  snapshot     PortfolioSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  symbol       String
  name         String
  shares       BigInt
  valueUsd     BigInt
  pctOfPort    Float // weight = value / portfolio total
  putCall      String? // "PUT" | "CALL" | null (the bearish/options tell)
  action       String // NEW | ADD | TRIM | EXIT | HOLD
  qoqSharesPct Float? // share-count change vs prior quarter (null if NEW/unknown)
  rank         Int // by value within the portfolio

  @@index([snapshotId])
  @@index([symbol])
}

// A disclosed congressional trade (Senate or House). `key` is a deterministic
// dedupe hash so daily ingest is idempotent. Amounts are reported as RANGES.
model PoliticalTrade {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  chamber      String // "senate" | "house"
  memberName   String
  memberId     String? // senateID / house id from the feed
  district     String?
  symbol       String
  assetName    String
  side         String // "BUY" | "SELL"
  amountRange  String // "$1,001 - $15,000"
  amountMinUsd Int? // parsed low bound — for ranking by size
  txnDate      DateTime
  disclosedAt  DateTime
  link         String?
  fetchedAt    DateTime @default(now())

  @@index([symbol])
  @@index([txnDate])
}

// An insider (Form 4) transaction. Source is "fmp" or "openinsider"; the
// top-buys board filters to open-market PURCHASES (txnType "P-Purchase"), not
// option exercises/grants. `key` makes ingest idempotent.
model InsiderTrade {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  symbol       String
  companyName  String?
  insiderName  String
  insiderTitle String? // typeOfOwner (e.g. "officer: CEO", "director")
  side         String // "BUY" | "SELL"
  txnType      String // FMP transactionType code (P-Purchase, S-Sale, ...)
  shares       Int
  priceUsd     Float
  valueUsd     Float // shares * price
  txnDate      DateTime
  filedAt      DateTime
  source       String // "fmp" | "openinsider"
  link         String?
  fetchedAt    DateTime @default(now())

  @@index([symbol])
  @@index([txnDate])
  @@index([side])
}

// Agent heartbeat — read by /api/health and the dashboard.
model AgentState {
  id            Int       @id @default(1)
  bootAt        DateTime?
  lastTickAt    DateTime?
  lastSessionAt DateTime?
  note          String?
  // On-demand discovery-hunt refresh: a member sets this from the Discover tab; the
  // runner's tick picks it up, runs the hunt off-schedule, and clears it.
  huntRequestedAt DateTime?
  huntRequestedBy String?
  // Directed hunt (D38): the member's plain-English brief that steers the next
  // on-demand hunt ("emerging medical names about to post trial data"). Also the
  // record powering the Hunt page's "directed hunt" banner. A blank refresh and the
  // daily scheduled hunt clear it (broad run); a briefed submit overwrites it.
  huntBrief     String?
  updatedAt     DateTime  @updatedAt
}

// Agent self-scheduling: a decision session can queue its own future trading
// check-in for later TODAY (e.g. "wake me at 2:05pm for the Fed"). The runner's
// tick fires due PENDING wakeups (market hours only, drawing on the ad-hoc
// decision budget) and marks them FIRED. Same-day, market hours only for now.
enum WakeupStatus {
  PENDING
  FIRED
  CANCELLED
}

model AgentWakeup {
  id        Int          @id @default(autoincrement())
  dueAt     DateTime
  reason    String
  createdBy String // the session label that scheduled it
  status    WakeupStatus @default(PENDING)
  createdAt DateTime     @default(now())
  firedAt   DateTime?

  @@index([status, dueAt])
}

// Conviction tally (Cam, 2026-06-17): every agent BUY/SELL proposal, logged at
// the propose_order boundary — including conviction-gate REJECTIONS, which
// refuse() before the DECISION journal is ever written. Lets us track the
// agent's per-trade thesis confidence against its standing dossier confidence
// over time: is it systematically under-confident at the trigger, or was the
// 2026-06-17 Fed-day caution a one-off? priceCents is the quote at proposal
// time so we can later retro whether "waiting" actually helped.
model TradeProposal {
  id                Int      @id @default(autoincrement())
  at                DateTime @default(now())
  symbol            String
  side              String // BUY | SELL
  qty               Int
  tradeConfidence   Int? // per-trade thesis confidence (the conviction-gate input)
  dossierConfidence Int? // latest dossier confidence at proposal time
  dossierStance     String? // latest dossier stance at proposal time
  accepted          Boolean
  status            String? // FILLED | PENDING | REJECTED
  rejectReason      String? // which rail fired (esp. the conviction gate)
  priceCents        Int? // ask (BUY) / bid (SELL) at proposal time, native ccy
  targetCents       Int?

  @@index([at])
  @@index([symbol])
}
