generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// All money values are integer cents (CAD unless noted). All quantities are
// whole shares — fractional shares are not in the v1 universe.

enum RiskLevel {
  CAUTIOUS
  BALANCED
  AGGRESSIVE
}

enum OrderSide {
  BUY
  SELL
}

enum OrderType {
  MARKET
  LIMIT
}

enum OrderStatus {
  PENDING
  FILLED
  CANCELLED
  REJECTED
}

enum JournalKind {
  SYSTEM
  RESEARCH
  DECISION
  TRADE
  RETRO
  LESSON
  NOTE // a human note added on a stock page ("The record")
}

enum ReportKind {
  EOD
  WEEKLY
  CHANGE // daily plain-English "what changed in the app" report for Graham (3am ET)
}

model Account {
  id        Int      @id @default(1)
  // CAD cash. USD cash is held separately (multi-currency — IBKR holds both, D33);
  // NAV converts USD→CAD at the BoC rate. Other currencies would warrant a table.
  cashCents    Int @default(0)
  usdCashCents Int @default(0)
  updatedAt DateTime @updatedAt
}

model Settings {
  id                  Int       @id @default(1)
  riskLevel           RiskLevel @default(BALANCED)
  feeBudgetCentsMonth Int       @default(2000)
  killSwitch          Boolean   @default(false)
  killSwitchBy        String?
  killSwitchAt        DateTime?
  agentVersion        String    @default("v1.48-phase4")
  // FX-approval guardrail (D62): member-set dials bounding CAD→USD conversions.
  // The agent may REQUEST any amount (request_fx); a member must approve each one,
  // and these caps bite at APPROVAL. 0 = no limit; usdAllocationCapPct 100 = all-USD ok.
  fxMaxPerRequestCents Int      @default(0)
  fxMaxPerWeekCents    Int      @default(0)
  usdAllocationCapPct  Int      @default(100)
  // Manual 5-hour usage-window reset instant (Cam 2026-06-25). The Max plan's rolling
  // window slides with usage and the agent's token can't read it, so an owner sets when
  // the current window resets (e.g. "3pm ET") on /admin/usage and the page counts down to it.
  maxWindowResetAt    DateTime?
  updatedBy           String?
  updatedAt           DateTime  @updatedAt
}

// The GRQ Daily masthead's rotating quote/joke (lib/dailyquote.ts). Moved out of a
// hardcoded array so members can add/edit/reorder/disable lines from Settings — no
// deploy. Selection is deterministic per Toronto-day (hash over enabled rows, in
// sortOrder); `pinnedDate` forces a specific line on a chosen day (overrides the hash).
model DailyQuote {
  id         Int      @id @default(autoincrement())
  text       String   @unique
  sortOrder  Int      @default(0)
  enabled    Boolean  @default(true)
  pinnedDate String? // YYYY-MM-DD (Toronto) — force this line that day; null = normal rotation
  createdAt  DateTime @default(now())
  createdBy  String?

  @@index([sortOrder])
}

// A CAD→USD (or USD→CAD) conversion the agent REQUESTS and a member APPROVES —
// the FX-approval guardrail (D62). The agent can ask for any amount; money only
// moves when a member approves, bounded by the Settings fx* dials + the kill switch.
// A member can also create one already-approved (the manual "Convert" escape hatch).
model FxRequest {
  id               Int       @id @default(autoincrement())
  createdAt        DateTime  @default(now())
  fromCurrency     String    @default("CAD")
  toCurrency       String    @default("USD")
  amountUsdCents   Int       // USD the agent wants to end up with
  estCadCents      Int       // est. CAD cost at request time (BoC rate)
  reason           String
  symbol           String?   // the name it's trying to fund (deep link), if any
  status           String    @default("PENDING") // PENDING|APPROVED|REJECTED|EXECUTED|FAILED
  requestedBy      String    @default("agent")   // "agent" | a member email (manual convert)
  decidedBy        String?   // member email who approved/rejected
  decidedAt        DateTime?
  note             String?   // member's note on approve/reject
  executedRate     Float?    // realized USD/CAD
  executedCadCents Int?      // CAD actually debited
  executedUsdCents Int?      // USD actually credited
  commissionCents  Int?
  failReason       String?

  @@index([status])
  @@index([createdAt])
}

model Contribution {
  id            Int      @id @default(autoincrement())
  at            DateTime @default(now())
  amountCents   Int
  // Who put this money in ("Cam" | "Graham"). Ownership is data, not code —
  // the app supports single-owner, joint (CRA: gains allocate by contribution
  // proportion), or future multi-account. See docs/OWNERSHIP.md.
  contributor   String?
  // XIC mid price when the money arrived — anchors the "vs just buying XIC" benchmark.
  xicPriceCents Int?
  note          String?
}

model Order {
  id                Int            @id @default(autoincrement())
  createdAt         DateTime       @default(now())
  symbol            String
  side              OrderSide
  type              OrderType
  qty               Int
  limitPriceCents   Int?
  status            OrderStatus    @default(PENDING)
  filledQty         Int            @default(0)
  avgFillPriceCents Int?
  commissionCents   Int            @default(0)
  placedBy          String
  reason            String?
  rejectReason      String?
  broker            String         @default("sim")
  // Broker-side order id (IBKR). Stored when an order is left PENDING (its fill
  // landed after our synchronous poll window) so the per-tick finaliser can resolve
  // it to a fill and write the Trade/journal — keeps the ledger from silently
  // missing slow fills. Null for sim orders and legacy rows.
  brokerOrderId     String?
  trades            Trade[]
  journal           JournalEntry[]

  @@index([createdAt])
  @@index([status])
}

model Trade {
  id               Int       @id @default(autoincrement())
  orderId          Int
  order            Order     @relation(fields: [orderId], references: [id])
  at               DateTime  @default(now())
  symbol           String
  side             OrderSide
  qty              Int
  priceCents       Int
  commissionCents  Int
  realizedPnlCents Int?

  @@index([at])
}

model Position {
  symbol       String   @id
  qty          Int
  avgCostCents Int
  // Native currency of avgCostCents + this name's quotes ("CAD" | "USD"). NAV/sizing
  // convert USD→CAD at the BoC rate (D33). Defaults CAD so existing rows are unchanged.
  currency     String   @default("CAD")
  openedAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model NavSnapshot {
  id             Int      @id @default(autoincrement())
  at             DateTime @default(now())
  navCents       Int
  cashCents      Int
  positionsCents Int
  // What the same contributions would be worth in XIC (null if unknowable).
  benchmarkCents Int?
  note           String?

  @@index([at])
}

model JournalEntry {
  id           Int         @id @default(autoincrement())
  at           DateTime    @default(now())
  kind         JournalKind
  symbol       String?
  title        String
  body         String
  confidence   Int?
  // JSON array of source strings that fed this entry (attribution — D13).
  sourcesJson  String?
  // Dossier price targets (Phase 1 "expected return"): a near-term swing target
  // (+ horizon in trading days) and a 12-month target, both in cents. These power
  // the expected-return figures on the Today page's "On the Radar".
  targetNearCents Int?
  targetNearDays  Int?
  targetFarCents  Int?
  // Plain-English "why" — 3–5 palatable bullets a non-expert can read, explaining
  // the agent's read on the stock. Surfaced on the stock page's bottom-line card.
  bottomLine      String?
  // The agent's OWN call (its judgment), distinct from the deterministic signal
  // consensus (a technicals formula). One of BUY/ACCUMULATE/HOLD/WATCH/TRIM/AVOID/SELL.
  // Where this diverges from the signal read, that divergence is the point.
  stance          String?
  // "What would change our mind" (confidence levers): a JSON array of the specific,
  // falsifiable things that would reframe this call — each a {gap, direction, magnitude,
  // kind, trigger, retrievable}. Decomposes what's pinning confidence below 100 (a gap we
  // could close, or a catalyst still to land). Shape + parse in lib/confidence-levers.ts;
  // shown under the bottom line. Pure display — never touches the order gate. Null = not filed.
  confidenceLeversJson String?
  // How under-the-radar a hunt find is (D38): the agent's 1–5 read — 5 = a deep cut
  // almost nobody covers, 1 = a well-followed name. Surfaced as the obscurity badge
  // on The Hunt and used to sort obscure-first. Null for non-hunt entries.
  obscurity       Int?
  // The find's listing (D51): the exchange the agent researched it on — NYSE/NASDAQ/
  // AMEX/TSX/TSXV/CSE/NEO. A BARE ticker is ambiguous (AII = American Integrity on
  // NYSE but Almonty on TSX), so this resolves the EXACT listing — the suffixed symbol
  // (yahooForListing) drives the find's quote, bars, and logo so we never show a
  // same-ticker different-company's price/chart. companyName = the FMP-confirmed name
  // for that listing (the identity record + display name). Null on legacy/unresolved.
  exchange        String?
  companyName     String?
  agentVersion String      @default("v1.48-phase4")
  orderId      Int?
  order        Order?      @relation(fields: [orderId], references: [id])

  @@index([at])
  @@index([kind])
}

model Report {
  id        Int        @id @default(autoincrement())
  date      DateTime
  kind      ReportKind
  title     String
  body      String
  statsJson String?
  createdAt DateTime   @default(now())

  @@unique([date, kind])
}

// Daily OHLCV history — feeds the signals layer (2.5d) and the stock-page
// sparklines. Backfilled 1y, then maintained nightly after close.
model Bar {
  symbol     String
  date       DateTime
  openCents  Int
  highCents  Int
  lowCents   Int
  closeCents Int
  volume     Int

  @@id([symbol, date])
  @@index([symbol, date])
}

// Latest delayed quote per symbol. The agent's tick loop keeps these warm;
// web reads them (with on-demand fallback fetch) so request paths stay fast.
model Quote {
  symbol       String   @id
  bidCents     Int
  askCents     Int
  midCents     Int
  dayChangeBps Int      @default(0)
  at           DateTime
  source       String   @default("yahoo-delayed")
}

// The agent's FOCUS list — its shortlist of ACTIVE universe names it's actively
// monitoring for an entry, with conditional trigger notes ("watching ABX for a
// $54 hold"). Distinct from the human watchlist, which is now CANDIDATE members
// (2.8). Set by the agent via set_focus (ACTIVE members only). Physical table
// kept as "Watchlist" via @@map so the rename is zero-migration; the model name
// is what code uses.
model AgentFocus {
  symbol  String   @id
  note    String?
  addedAt DateTime @default(now())

  @@map("Watchlist")
}

// The universe pipeline (2.7; reworked D-watch): CANDIDATE = tracked/researched,
// not tradeable; ACTIVE = the agent may buy it; RETIRED = stop researching
// (history is never deleted). Promotion is now SINGLE-ACTOR — any member OR the
// agent may promote (the automated liquidity screen still gates it); the §6 order
// gate (ACTIVE-required-to-BUY) is unchanged. Status no longer means "watchlist":
// a personal watch is the separate StockWatch table below, independent of status
// (a name can be watched AND ACTIVE at once). The two-person fields below
// (promotionRequestedBy/At, proposedTier) are RETIRED in code — kept on the model
// for expand/contract safety; drop in a follow-up migration.
enum UniverseStatus {
  CANDIDATE
  ACTIVE
  RETIRED
}

// Who personally WATCHES a stock (D-watch). Many-to-many: each (symbol, member)
// pair is one row, so a name can be watched by several members and shown as a
// stack of avatars. Independent of UniverseMember.status — watching does not make
// a name tradeable, and promoting does not un-watch it. Watchers are humans only
// (the agent's interest lives in the universe/AgentFocus, not here). `email` is
// the member's stable identity (lib/users.ts), resolved to a face via
// lib/people.ts personByEmail(). NB the physical "Watchlist" table name is already
// taken by AgentFocus (@@map above) — this stays the default "StockWatch".
model StockWatch {
  symbol  String
  email   String
  addedAt DateTime @default(now())

  @@id([symbol, email])
  @@index([email])
  @@index([symbol])
}

model UniverseMember {
  symbol               String         @id
  yahoo                String
  name                 String
  tier                 String? // etf | large | mid — set at promotion
  status               UniverseStatus @default(CANDIDATE)
  addedBy              String?
  addedAt              DateTime       @default(now())
  promotionRequestedBy String?
  promotionRequestedAt DateTime?
  proposedTier         String?
  note                 String?
  // Resolved company logo URL (favicon by domain; FMP logos later). Lifecycle:
  // null = not yet resolved, "" = resolved but none found, URL = use it.
  logoUrl              String?
  // Fundamentals from FMP (refreshed by the agent runner) — power the stock
  // filters (country / exchange / industry / cap) and per-name context.
  // marketCapM is millions in the listing's own currency; bucketing the cap for
  // filters makes the currency moot. fmpAt = last refresh (null = never).
  sector               String?
  industry             String?
  country              String?
  currency             String?
  exchange             String?
  marketCapM           Int?
  fmpAt                DateTime?
  updatedAt            DateTime       @updatedAt
}

// On-demand + rotation research queue — the agent runner processes it.
enum ResearchStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

model ResearchRequest {
  id          Int            @id @default(autoincrement())
  symbol      String
  requestedBy String
  status      ResearchStatus @default(QUEUED)
  at          DateTime       @default(now())
  completedAt DateTime?
  error       String?

  @@index([status])
  @@index([at])
}

// Member steering for the agent (2.6c): BLOCKED = agent may never buy it
// (sells always allowed); PINNED = always on the watchlist. Binds the agent
// only — members' manual orders are exempt.
enum DirectiveType {
  PINNED
  BLOCKED
}

model SymbolDirective {
  symbol    String        @id
  directive DirectiveType
  by        String
  note      String?
  at        DateTime      @default(now())
}

// Source scoreboard (2.6a): retros grade every source a resolved thesis cited.
// +1 pointed the right way, −1 misleading, 0 neutral. Signal families are
// sources too ("signal:rsi").
model SourceGrade {
  id        Int      @id @default(autoincrement())
  at        DateTime @default(now())
  source    String
  symbol    String?
  grade     Int
  note      String?
  journalId Int?

  @@index([source])
  @@index([symbol])
}

// Per-member chat threads with the agent (read-only tools — chat can never
// trade). `owner` is the member whose thread this belongs to (their email);
// `email` is the author (a member email, or "agent" for assistant turns). Cam
// and Graham each have their own thread and can toggle into the other's.
model ChatMessage {
  id      Int      @id @default(autoincrement())
  at      DateTime @default(now())
  owner   String   @default("") // the member whose thread this is (email)
  email   String // author: a member email, or "agent"
  role    String // "user" | "assistant"
  content String

  @@index([owner, at])
  @@index([at])
}

// Member-to-member direct messages — the two-person fund's own thread (Cam ↔
// Graham), distinct from the read-only agent chat above (ChatMessage). A bare DM
// is just `body`; a "share" carries `symbol` (+ optional `panel`) so tapping its
// push deep-links the recipient straight to that dossier panel. Each message is
// pushed to the recipient (category "messages") and the open thread polls for new
// rows; `readAt` (null = unread) drives the inbox badge. Both members read the one
// shared thread, so direction is just (fromEmail → toEmail).
model DirectMessage {
  id        Int       @id @default(autoincrement())
  at        DateTime  @default(now())
  fromEmail String // author (normalized lowercase)
  toEmail   String // recipient — the other member (normalized lowercase)
  body      String    @default("") // the comment / chat text (empty for a bare share)
  symbol    String? // attached dossier, if this is a share
  panel     String? // attached panel key (e.g. "analyst"), if a specific panel was shared
  readAt    DateTime? // when the recipient opened the thread; null = unread

  @@index([at])
  @@index([toEmail, readAt])
}

// Cached agent explanations of finance/investing concepts (the literacy pillar's
// "explain this" — docs/LITERACY.md). Keyed by the normalized term so the second
// reader to click "shell company" pays $0 and gets it instantly.
model Explainer {
  key  String   @id // normalized term (lowercase, trimmed)
  term String
  body String
  at   DateTime @default(now())
}

// Human research notes — Cam & Graham's own desk (the Research tab is for human
// research, distinct from the agent's auto-dossiers). Optionally tagged to a symbol.
model Note {
  id     Int      @id @default(autoincrement())
  at     DateTime @default(now())
  author String
  symbol String?
  body   String

  @@index([at])
}

// --- Smart Money (D27) -------------------------------------------------------
// What notable public portfolios are doing, surfaced as colour/leads (not trade
// instructions). EXTERNAL reference data, not fund money: dollar values are stored
// as REPORTED (USD from US filings), like IndexQuote keeps index levels as plain
// numbers — never the integer-CAD-cents rule, because we never trade off these
// directly. BigInt where a 13F's market value overflows Int32 (Berkshire ~$263B).
// Refreshed by the agent runner: congress + insider daily, 13F when a new filing
// date appears (quarterly, ~45-day lag). See docs/DATA-SOURCES.md tiers 4 & 5.

// One manager's 13F as of a quarter-end. Holdings hang off it.
model PortfolioSnapshot {
  id            Int                @id @default(autoincrement())
  cik           String
  holderName    String
  asOf          DateTime // 13F "date" — quarter-end
  filedAt       DateTime? // when the 13F was filed (the ~45-day lag is asOf→filedAt)
  totalValueUsd BigInt // marketValue
  holdingsCount Int
  securitiesAdded   Int? // new positions this quarter
  securitiesRemoved Int? // exited positions this quarter
  perf1yPct     Float? // trailing 1-yr portfolio performance (FMP holder-perf)
  fetchedAt     DateTime           @default(now())
  holdings      PortfolioHolding[]

  @@unique([cik, asOf])
  @@index([cik])
}

// One line of a 13F (a symbol can appear as common + PUT + CALL — kept distinct,
// matching the filing). action is derived by diffing against the prior quarter.
model PortfolioHolding {
  id           Int               @id @default(autoincrement())
  snapshotId   Int
  snapshot     PortfolioSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  symbol       String
  name         String
  shares       BigInt
  valueUsd     BigInt
  pctOfPort    Float // weight = value / portfolio total
  putCall      String? // "PUT" | "CALL" | null (the bearish/options tell)
  action       String // NEW | ADD | TRIM | EXIT | HOLD
  qoqSharesPct Float? // share-count change vs prior quarter (null if NEW/unknown)
  rank         Int // by value within the portfolio

  @@index([snapshotId])
  @@index([symbol])
}

// A disclosed congressional trade (Senate or House). `key` is a deterministic
// dedupe hash so daily ingest is idempotent. Amounts are reported as RANGES.
model PoliticalTrade {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  chamber      String // "senate" | "house"
  memberName   String
  memberId     String? // senateID / house id from the feed
  district     String?
  symbol       String
  assetName    String
  side         String // "BUY" | "SELL"
  amountRange  String // "$1,001 - $15,000"
  amountMinUsd Int? // parsed low bound — for ranking by size
  txnDate      DateTime
  disclosedAt  DateTime
  link         String?
  fetchedAt    DateTime @default(now())

  @@index([symbol])
  @@index([txnDate])
}

// An insider (Form 4) transaction. Source is "fmp" or "openinsider"; the
// top-buys board filters to open-market PURCHASES (txnType "P-Purchase"), not
// option exercises/grants. `key` makes ingest idempotent.
model InsiderTrade {
  id           Int      @id @default(autoincrement())
  key          String   @unique
  symbol       String
  companyName  String?
  insiderName  String
  insiderTitle String? // typeOfOwner (e.g. "officer: CEO", "director")
  side         String // "BUY" | "SELL"
  txnType      String // FMP transactionType code (P-Purchase, S-Sale, ...)
  shares       Int
  priceUsd     Float
  valueUsd     Float // shares * price
  txnDate      DateTime
  filedAt      DateTime
  source       String // "fmp" | "openinsider"
  link         String?
  fetchedAt    DateTime @default(now())

  @@index([symbol])
  @@index([txnDate])
  @@index([side])
}

// Macro events (D81) — discrete deltas detected off the BoC/FRED daily snapshot
// (a rate decision, a CPI print, a notable yield/FX move), plus forward calendar
// items (scheduledFor set). An INPUT the agent weighs in context, never the gate.
// Written once per ET day by lib/macro-events.ts; full plan in docs/NEWS-AND-EVENTS.md.
model MarketEvent {
  id           Int       @id @default(autoincrement())
  detectedAt   DateTime  @default(now())
  at           DateTime // when observed/occurred (the snapshot day for a delta)
  scheduledFor DateTime? // forward calendar items (FOMC/CPI dates); null for observed deltas
  kind         String // RATE_DECISION | CPI_PRINT | YIELD_MOVE | FX_MOVE | CALENDAR
  region       String // CA | US
  series       String? // overnightRate | fedFunds | cpiYoY | usCpiYoY | ust10y | goc5yr | usdcad
  headline     String
  value        Float?
  prevValue    Float?
  source       String // BoC | FRED | FMP

  @@unique([kind, region, series, at]) // idempotent: one delta per series per day
  @@index([at])
}

// Daily macro snapshot (D81) — one upserted row per ET day. The most recent prior
// row is the baseline macro-events.ts diffs the live getMacro() against to detect
// deltas. Floats (rates/FX), not money, so the int-cents rule doesn't apply here.
model MacroDaily {
  date          String   @id // YYYY-MM-DD (ET)
  usdcad        Float?
  overnightRate Float?
  goc5yr        Float?
  cpiYoY        Float?
  fedFunds      Float?
  ust10y        Float?
  usCpiYoY      Float?
  at            DateTime @default(now())
}

// News articles (D81, M2) — FMP general + per-symbol news, captured/deduped (unique URL)
// and Haiku-TRIAGED into a relevance-scored digest. The agent reads the digest (never raw
// articles); the human pages read this store instead of live FMP. An INPUT, never the gate.
// Triage fields are null until the Haiku pass runs. lib/news/* + agent/news-triage.ts.
model NewsArticle {
  id          Int       @id @default(autoincrement())
  fetchedAt   DateTime  @default(now())
  publishedAt DateTime
  source      String // "fmp-general" | "fmp-stock"
  publisher   String
  title       String
  url         String    @unique // natural dedupe key
  imageUrl    String?
  text        String? // article lede/snippet from the source (FMP `text`) — powers the on-page paragraph summary
  symbol      String? // primary tagged ticker (null = general market) — the capture-time symbol
  symbolsJson String? // extra entity tags (JSON array of tickers), Haiku-assigned
  // --- triage (Haiku; null until triaged) ---
  summary     String?
  sentiment   String? // POS | NEU | NEG
  relevance   Int? // 0–100 materiality to a tracked name / the macro thesis
  category    String? // EARNINGS | GUIDANCE | MNA | MACRO | LEGAL | PRODUCT | RATING | OTHER
  triagedAt   DateTime?

  @@index([publishedAt])
  @@index([symbol])
  @@index([triagedAt])
}

// Tier 3 — Options positioning, computed by us from CBOE's free delayed feed (lib/options/*).
// One cached row per symbol per ET day. A SIGNAL about the underlying — the fund never trades
// options. US-listed names only; CA/illiquid names never get a row (no listed options).
model OptionsDaily {
  id            Int      @id @default(autoincrement())
  fetchedAt     DateTime @default(now())
  symbol        String // the STORED symbol (looked up by the stock page / agent by what they know)
  date          String // ET YYYY-MM-DD — the cache key (one row per name per day; refreshed ~hourly)
  covered       Boolean @default(true) // false = a remembered "no listed options" miss (day-scoped negative cache)
  spotCents     Int
  netGex        Float // $ dealer gamma per 1% move (calls + / puts −); >0 dampens, <0 amplifies
  regime        String // "positive" | "negative"
  callWallCents Int? // heaviest call-gamma strike (resistance/magnet)
  putWallCents  Int? // heaviest put-gamma strike (support)
  pcOI          Float? // put/call open-interest ratio
  pcVol         Float? // put/call volume ratio (today's flow)
  atmIvBps      Int? // ~30d at-the-money implied vol, bps
  skewBps       Int? // 25-delta skew (put IV − call IV), bps
  callOI        Int?
  putOI         Int?
  callVol       Int?
  putVol        Int?

  @@unique([symbol, date])
  @@index([symbol])
  @@index([fetchedAt])
}

// Tier 8 — Social sentiment, aggregated by us from free keyless feeds (lib/social/*): ApeWisdom
// (pre-aggregated Reddit mention counts) + Stocktwits (user-tagged Bullish/Bearish). One cached
// row per symbol per ET day. A RISK/CROWDING signal about the underlying — never gates a trade,
// and on probation in the source scoreboard (noisy, gameable). Velocity is computed vs OUR stored
// ≤7-day mention history, not a vendor field. US-centric; CA/off-radar names go dark (covered=false,
// which is itself a signal: no retail crowding). docs/DATA-SOURCES.md tier 8 + DECISIONS D89.
model SocialDaily {
  id         Int      @id @default(autoincrement())
  fetchedAt  DateTime @default(now())
  symbol     String // the STORED symbol (looked up by the stock page / agent by what they know)
  date       String // ET YYYY-MM-DD — the cache key (one row per name per day)
  covered    Boolean  @default(true) // false = below the mention floor / no chatter (day-scoped)
  mentions   Int      @default(0) // Reddit mentions today (ApeWisdom rolling 24h)
  velocity   Float? // today's mentions ÷ our trailing ≤7-day avg (>1 heating up, <1 cooling)
  rank       Int? // position on the ApeWisdom board (lower = more talked-about)
  rankPrev   Int? // board rank 24h ago (momentum)
  upvotes    Int? // aggregate upvotes behind the mentions
  bullPct    Float? // Stocktwits Bullish ÷ (Bullish+Bearish), null when too few tags to trust
  bullSample Int? // # of sentiment-tagged Stocktwits messages behind bullPct
  buzz       Int      @default(0) // derived 0–100 ("how loud, and getting louder?") — level + velocity
  sources    String   @default("") // which feeds contributed, e.g. "apewisdom,stocktwits"

  @@unique([symbol, date])
  @@index([symbol])
  @@index([fetchedAt])
}

// Agent heartbeat — read by /api/health and the dashboard.
model AgentState {
  id            Int       @id @default(1)
  bootAt        DateTime?
  lastTickAt    DateTime?
  lastSessionAt DateTime?
  note          String?
  // On-demand discovery-hunt refresh: a member sets this from the Discover tab; the
  // runner's tick picks it up, runs the hunt off-schedule, and clears it.
  huntRequestedAt DateTime?
  huntRequestedBy String?
  // Directed hunt (D38): the member's plain-English brief that steers the next
  // on-demand hunt ("emerging medical names about to post trial data"). Also the
  // record powering the Hunt page's "directed hunt" banner. A blank refresh and the
  // daily scheduled hunt clear it (broad run); a briefed submit overwrites it.
  huntBrief     String?
  // Held-position trigger anchors (Cam 2026-06-24): the day-% at which we last CHECKED
  // each held name, so evaluateTriggers fires on the MOVE-SINCE-LAST-CHECK (a fresh ±4%
  // leg), not the absolute day-move. Persisted so a restart can't wipe it and resurrect
  // the same-move drumbeat. JSON: { "ATD": { "bps": 1400, "day": "2026-06-24" } }.
  triggerAnchorsJson String?
  // Ad-hoc decision budget, persisted (Cam 2026-06-24): the count of ad-hoc decision
  // sessions (held-position escalations + self-scheduled wakeups) used on `adhocDate`.
  // Was in-memory and reset on every restart, defeating the daily cap (8 restarts/day
  // let ATD re-escalate ~13×). Auto-resets when the ET date rolls over.
  adhocDate     String?
  adhocCount    Int       @default(0)
  updatedAt     DateTime  @updatedAt
}

// The agent's standing to-do list (Cam 2026-06-24). Instead of self-scheduling a
// separate decision session + push for every "revisit X when its dossier lands"
// follow-up, the agent files it here and the NEXT hourly intraday check-in works
// through it — folding follow-ups into the scheduled cadence rather than spawning
// noise. schedule_checkin stays for the rare event that genuinely can't wait an hour.
model AgentAgendaItem {
  id         Int       @id @default(autoincrement())
  body       String // the to-do, e.g. "Revisit DRX once its dossier lands — promote if ≥Buy/75"
  symbol     String? // the name it concerns, if any (for display + deep-link)
  status     String    @default("OPEN") // OPEN | DONE | DROPPED
  createdBy  String // the session label that added it
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?
  outcome    String? // how it was handled, set when resolved

  @@index([status])
}

// Agent self-scheduling: a decision session can queue its own future trading
// check-in for later TODAY (e.g. "wake me at 2:05pm for the Fed"). The runner's
// tick fires due PENDING wakeups (market hours only, drawing on the ad-hoc
// decision budget) and marks them FIRED. Same-day, market hours only for now.
enum WakeupStatus {
  PENDING
  FIRED
  CANCELLED
}

model AgentWakeup {
  id        Int          @id @default(autoincrement())
  dueAt     DateTime
  reason    String
  createdBy String // the session label that scheduled it
  status    WakeupStatus @default(PENDING)
  createdAt DateTime     @default(now())
  firedAt   DateTime?

  @@index([status, dueAt])
}

// --- Push notifications (D53) ------------------------------------------------
// iOS push (APNs). The same events that fan out to Discord (web/agent/alerts.ts)
// also fan out to each member's registered devices, gated by their per-user
// NotificationPreference. Members only — viewers don't get a device row.

// A registered APNs device token, keyed by member email. A member can have many
// devices (phone + iPad); the unique pair makes re-registration idempotent. The
// sender prunes a token when APNs reports it Unregistered/BadDeviceToken (410).
model DeviceToken {
  id           Int      @id @default(autoincrement())
  email        String // member email (normalized lowercase)
  token        String // APNs device token (hex)
  platform     String   @default("ios") // "ios" (room for "android" later)
  // The app build env the token belongs to: "production" (TestFlight/App Store)
  // or "sandbox" (Xcode debug build) — they use DIFFERENT APNs gateways, so a
  // token must be sent to the gateway that minted it.
  apnsEnv      String   @default("production")
  registeredAt DateTime @default(now())
  lastUsedAt   DateTime @updatedAt

  @@unique([email, token])
  @@index([email])
}

// Per-user notification toggles. One row per member (email is the PK). Every
// category defaults ON ("default opt in for all categories" — Cam, 2026-06-22).
// trades + risk are NOT stored here: they're force-on in code (non-toggleable),
// as is any critical-severity alert (agent crash / drawdown halt). A missing row
// means "never touched settings" → treated as all-on. priceTargets is reserved
// for the later "set a target, get pinged" feature (no event wired to it yet).
model NotificationPreference {
  email        String   @id // member email (normalized lowercase)
  dossiers     Boolean  @default(true) // a requested research dossier is ready
  hunt         Boolean  @default(true) // new hunt names / directed-hunt / smart-money scan
  agentMoves   Boolean  @default(true) // the agent self-tracks or self-promotes a name
  reports      Boolean  @default(true) // morning plan / midday / EOD / weekly review
  checkins     Boolean  @default(true) // SCHEDULED fund-level check-ins (the hourly clock review)
  holdingChecks Boolean @default(true) // per-HOLDING check-ins (a position's move / revisit) — noisy as the portfolio grows
  members      Boolean  @default(true) // the OTHER member's universe/directive/kill actions
  messages     Boolean  @default(true) // the OTHER member messages you or shares a stock (D61)
  system       Boolean  @default(true) // agent restarts, data-feed/broker hiccups (non-critical)
  priceTargets Boolean  @default(true) // price alerts you set (The Wire, Phase 2) — now wired
  optionsDesk  Boolean  @default(true) // the experimental Options Desk opened/settled an option (sandbox nudge)
  updatedAt    DateTime @updatedAt
}

// The web notification center — the bell in the header. One row per recipient
// member per notifiable event, written at the SAME chokepoint as the iOS push
// fan-out (lib/push/notify.ts → pushNotify), so the in-app feed mirrors exactly
// what got pushed. Persisted independently of DeviceToken: a member with no phone
// still has a feed. The `messages` category is intentionally NOT stored here — the
// envelope/unread badge (DirectMessage) owns member conversations; the bell owns
// fund + agent activity (trades, risk, reports, hunt, dossiers, agent moves, …).
model Notification {
  id       Int       @id @default(autoincrement())
  at       DateTime  @default(now())
  email    String // recipient member (normalized lowercase)
  category String // NotifCategory (trades|risk|fx|dossiers|hunt|agentMoves|reports|checkins|holdingChecks|members|system|priceTargets)
  severity String    @default("info") // "info" | "warning" | "critical"
  title    String
  body     String    @default("")
  symbol   String? // deep-link target (opens the dossier)
  panel    String? // deep-link panel within the dossier (e.g. "analyst")
  readAt   DateTime? // when the member opened the bell; null = unread

  @@index([email, readAt])
  @@index([email, id])
}

// Per-user price alerts (Phase 2 — The Wire). A member sets "ping me when SYMBOL
// crosses $X" from the stock page or The Wire; the agent runner checks active
// alerts each market-hours tick and fires a push (category "priceTargets") to the
// OWNER ONLY, then one-shots the alert (active=false, firedAt set). Money is integer
// cents, native to the symbol's listing currency (house rule: no floats, ever).
model PriceAlert {
  id             Int       @id @default(autoincrement())
  email          String // owner (normalized lowercase) — only this member is pinged
  symbol         String
  direction      String // "above" | "below" — the side the price must cross
  thresholdCents Int // trigger price, native currency
  currency       String    @default("CAD")
  note           String? // optional member note ("near my entry")
  active         Boolean   @default(true)
  createdAt      DateTime  @default(now())
  firedAt        DateTime? // set when it fires (one-shot); the alert then goes inactive

  @@index([email])
  @@index([active, symbol])
}

// --- Traffic / usage logging (admin dashboard) -------------------------------
// One row per page navigation, written by a client beacon (components/Tracker.tsx)
// → POST /api/track. Identity is resolved SERVER-SIDE from the session (never the
// client), so `email`/`role` are trustworthy. Everyone here is behind SSO (~9
// allowlisted humans), so there's no bot noise to filter. `section` is the
// friendly label (lib/sections.ts); `path` is the raw pathname for drill-down
// (e.g. which stock pages). Owner-only /admin aggregates this. No money, no PII
// beyond the email we already authenticate.
model PageView {
  id      Int      @id @default(autoincrement())
  at      DateTime @default(now())
  email   String // viewer/member email (normalized lowercase)
  role    String // "owner" | "member" | "viewer" — snapshot at view time
  path    String // raw pathname ("/stocks/AAPL")
  section String // friendly label ("Stock", "Watchlist", "Today")

  @@index([at])
  @@index([email])
  @@index([section])
}

// Conviction tally (Cam, 2026-06-17): every agent BUY/SELL proposal, logged at
// the propose_order boundary — including conviction-gate REJECTIONS, which
// refuse() before the DECISION journal is ever written. Lets us track the
// agent's per-trade thesis confidence against its standing dossier confidence
// over time: is it systematically under-confident at the trigger, or was the
// 2026-06-17 Fed-day caution a one-off? priceCents is the quote at proposal
// time so we can later retro whether "waiting" actually helped.
model TradeProposal {
  id                Int      @id @default(autoincrement())
  at                DateTime @default(now())
  symbol            String
  side              String // BUY | SELL
  qty               Int
  tradeConfidence   Int? // per-trade thesis confidence (the conviction-gate input)
  dossierConfidence Int? // latest dossier confidence at proposal time
  dossierStance     String? // latest dossier stance at proposal time
  accepted          Boolean
  status            String? // FILLED | PENDING | REJECTED
  rejectReason      String? // which rail fired (esp. the conviction gate)
  priceCents        Int? // ask (BUY) / bid (SELL) at proposal time, native ccy
  targetCents       Int?

  @@index([at])
  @@index([symbol])
}

// Per-session LLM token accounting (Cam 2026-06-24). Every runSession() writes one row from
// the Agent-SDK result message so we can inventory token/cost burn by session type. The agent
// shares Cam's Claude Max token (CLAUDE_CODE_OAUTH_TOKEN), so this is ALSO how we see how much
// of that shared quota the autonomous agent eats (the thing that drains Cam's interactive
// quota by late morning). Token counts are exact integers from the SDK; cost is stored as
// integer micro-USD (no floats — house rule), and may be 0 on a Max/OAuth token that doesn't
// meter cost — token counts are the source of truth for the rate-limit diagnosis.
model AgentUsage {
  id                  String   @id @default(cuid())
  at                  DateTime @default(now())
  label               String // session label, e.g. "checkin:11:00", "dossier:ATD", "startup-universe-review"
  model               String // primary model id, e.g. "claude-opus-4-8"
  status              String // "success" | the SDK result subtype on failure (error_max_turns, …)
  numTurns            Int      @default(0)
  durationMs          Int      @default(0)
  inputTokens         Int      @default(0) // fresh (uncached) input
  outputTokens        Int      @default(0)
  cacheCreationTokens Int      @default(0)
  cacheReadTokens     Int      @default(0)
  costMicroUsd        Int      @default(0) // SDK total_cost_usd × 1e6, rounded (0 if unmetered)
  modelUsageJson      String? // raw per-model breakdown (incl. subagent models)
  agentVersion        String?

  @@index([at])
  @@index([label])
}

// The Race (D68, Cam 2026-06-24) — a multi-model bake-off. At each decision/report session the
// SAME frozen prompt the live agent (the CHAMPION, Opus) ran on is handed to one or more
// CHALLENGER models (Phase 1: Sonnet) ONE-SHOT with NO tools — so each challenger sees the exact
// same SEED information the champion did, and the run is fully reproducible. A challenger can
// never trade: there is no order tool in its path and it never reaches the §6 gate (guardrail
// #1). One row per (session, model): the champion row carries what it actually did (its journal
// note / report body), challenger rows carry the parsed "what I would do" proposal + reasoning.
// Rows are tied together by sessionAt. Token/cost for each run is logged to AgentUsage (label
// "race:…"), so The Race doubles as a cost-per-model comparison too.
model ShadowRun {
  id           Int      @id @default(autoincrement())
  at           DateTime @default(now())
  sessionAt    DateTime // the champion session's start — the join key tying champion + challengers
  sessionKind  String // "morning" | "checkin" | "midday" | "eod" | "position"
  label        String // the session label, e.g. "checkin:13:00 ET"
  reason       String // human reason for the session
  model        String // the model id that produced this row
  role         String   @default("challenger") // "champion" | "challenger"
  // raw output: the champion's journal note / report body, OR the challenger's reasoning + JSON
  text         String
  // structured proposal — challengers on DECISION sessions only (null on narrative/report
  // sessions, on "no trade", and on the champion row, whose real action lives in Order/Trade)
  action       String? // "BUY" | "SELL" | "HOLD" | "NONE"
  symbol       String?
  qty          Int? // whole shares
  thesis       String?
  confidence   Int? // 0–100
  // The Race scoring (Cam 2026-06-25) — price snapshot at call time so we can mark every BUY/SELL
  // to the live price and compute what each model's call WOULD have made. Native currency (the
  // listing's ccy); entryCurrency lets the standings convert USD calls → CAD for a single board.
  // Null on HOLD/NONE/narrative rows and on any call we couldn't price (rendered "unpriced").
  entryPriceCents Int?
  entryCurrency   String? // "CAD" | "USD"
  agentVersion String?

  @@index([sessionAt])
  @@index([sessionKind])
  @@index([model])
}

// Bull Races (Cam 2026-06-25) — a configurable competition where each model ("bull") runs its OWN
// virtual paper account: its own cash, positions, trades, P&L. A PURE SANDBOX, fully isolated from
// the real fund — these tables never touch Account/Position/Trade or the §6 gate (guardrail #1).
// Every bull runs seed-only/no-tools each race session, so the field is level (no champion tool
// edge here). Books are CAD-denominated; US names fill at the live FX rate. See docs/THE-RACE.md.
model Race {
  id                 Int      @id @default(autoincrement())
  name               String
  status             String   @default("RUNNING") // RUNNING | PAUSED | ENDED
  cadence            String   @default("daily") // daily | hourly — which session slots fire
  startingStakeCents Int      @default(2500000) // each bull's starting CAD cash (CA$25k)
  createdAt          DateTime @default(now())
  startedAt          DateTime?
  endedAt            DateTime?
  entrants           RaceEntrant[]
}

// One "bull": a model running under a risk dial + optional persona. Multiple entrants may share a
// model (different dials/personas = different versions).
model RaceEntrant {
  id        Int      @id @default(autoincrement())
  raceId    Int
  race      Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  model     String // e.g. "claude-opus-4-8", "x-ai/grok-4.3"
  dial      String   @default("BALANCED") // CAUTIOUS | BALANCED | AGGRESSIVE (DIALS in policy.ts)
  persona   String? // optional style instruction ("momentum, high turnover")
  label     String // display name, e.g. "Grok · Aggressive"
  cashCents Int // current CAD cash
  status    String   @default("ACTIVE") // ACTIVE | RETIRED
  createdAt DateTime @default(now())
  positions RacePosition[]
  trades    RaceTrade[]
  calls     RaceCall[]
  navSnaps  RaceNavSnapshot[]

  @@index([raceId])
}

model RacePosition {
  id           Int         @id @default(autoincrement())
  entrantId    Int
  entrant      RaceEntrant @relation(fields: [entrantId], references: [id], onDelete: Cascade)
  symbol       String
  qty          Int
  avgCostCents Int // native currency
  currency     String      @default("CAD")
  openedAt     DateTime    @default(now())

  @@unique([entrantId, symbol])
  @@index([entrantId])
}

model RaceTrade {
  id               Int         @id @default(autoincrement())
  entrantId        Int
  entrant          RaceEntrant @relation(fields: [entrantId], references: [id], onDelete: Cascade)
  at               DateTime    @default(now())
  sessionAt        DateTime
  symbol           String
  side             String // BUY | SELL
  qty              Int
  priceCents       Int // native fill price
  currency         String      @default("CAD")
  commissionCents  Int // native
  realizedPnlCents Int? // CAD (SELL only)

  @@index([entrantId])
}

// Per-session decision audit — every bull, every race session (filled or not).
model RaceCall {
  id           Int         @id @default(autoincrement())
  entrantId    Int
  entrant      RaceEntrant @relation(fields: [entrantId], references: [id], onDelete: Cascade)
  sessionAt    DateTime
  action       String? // BUY | SELL | HOLD | NONE
  symbol       String?
  qty          Int?
  confidence   Int?
  thesis       String?
  text         String // full reasoning
  filled       Boolean     @default(false)
  rejectReason String? // race-gate rejection (cash, position cap, no quote, no-short, weekly cap)

  @@index([entrantId])
  @@index([sessionAt])
}

model RaceNavSnapshot {
  id                Int         @id @default(autoincrement())
  entrantId         Int
  entrant           RaceEntrant @relation(fields: [entrantId], references: [id], onDelete: Cascade)
  at                DateTime    @default(now())
  navCadCents       Int
  cashCents         Int
  positionsCadCents Int

  @@index([entrantId, at])
}

// Knowledge graph — Slice 2 (docs/KNOWLEDGE-GRAPH.md). Persisted company-relationship
// edges, recomputed by a deterministic nightly batch (lib/graph/edges.ts, no LLM).
// One row per directed (fromSymbol → toTicker) edge; the scan visits every tracked
// node so symmetric pairs persist in both directions. Read by the Today "also
// touches" lane and (Slice 3) the agent context. Never gates an order (§6 untouched).
model KnowledgeEdge {
  id         Int      @id @default(autoincrement())
  fromSymbol String // the universe symbol this edge belongs to ("NVDA", "AMD.US", "RY")
  toTicker   String // bare ticker of the related name (join key)
  toSymbol   String? // resolved universe symbol when the related name is tracked, else null
  weight     Int // 0–100 derived relatedness
  sources    String // CSV: "peer,coheld,comention,sector"
  why        String // human-readable provenance
  computedAt DateTime @default(now())

  @@unique([fromSymbol, toTicker])
  @@index([fromSymbol])
  @@index([toTicker])
}

// Market Base Layer (docs/MARKET-BASE-LAYER.md) — a wide, cheap awareness layer
// BELOW the universe: every real (non-ETF) company on NASDAQ/NYSE/TSX/TSXV, with a
// Tier-0 deterministic screen score and an optional Tier-1 Haiku light-tag. A name
// can be screened without being a CANDIDATE. The knowledge graph joins on `ticker`
// (bare) to carry a neighbour's read. An INPUT the agent weighs, never the gate.
model MarketScreen {
  id          Int       @id @default(autoincrement())
  symbol      String // FMP-native symbol (e.g. "NVDA", "RY.TO") — unique per exchange
  ticker      String // bare ticker (knowledge-graph join key)
  name        String
  exchange    String // NASDAQ | NYSE | TSX | TSXV
  sector      String?
  country     String?
  marketCapM  Int?
  priceCents  Int?
  currency    String?
  // Tier 0 — deterministic screen (no LLM)
  screenScore Int
  screenedAt  DateTime  @default(now())
  // Tier 1 — Haiku light-tag (null until tagged)
  tag         String? // INTERESTING | WATCH | PASS
  take        String? // one-line "worth a look?" note
  obscurity   Int? // 1–5
  taggedAt    DateTime?
  // Technical read — the deterministic signal (agent/signals.ts overallSignal), 7-point label
  // (Strong Buy…Strong Sell). Needs price bars, so computed (stale-first, bounded) only for the
  // actionable INTERESTING/WATCH names, nightly. Null = not computed (no bars / not actionable).
  signal      String?
  signalAt    DateTime?

  @@unique([symbol, exchange])
  @@index([screenScore])
  @@index([ticker])
  @@index([exchange])
}

// The Options Desk (docs/THE-OPTIONS-DESK.md) — a Bulls-style SANDBOX that pits a CONTROL
// (Opus, stock-only = the live fund's behaviour) against a TREATMENT (Opus + the power to BUY
// calls/puts) on the same book/cadence. PURE SANDBOX, fully isolated from the real fund — these
// tables never touch Account/Position/Trade or the §6 gate (guardrail #1). Buy-to-open ONLY (no
// selling/writing, no spreads, no shorting) → defined risk. Books are CAD-denominated; options are
// US-only (CBOE), filled in USD at the live FX rate. Option P&L is MODELED (CBOE delayed mid, or
// Black-Scholes from IV), never executable. Does NOT violate guardrail #3 (that bans options on the
// real broker path; this never trades real options, like the Bulls never really buy stock).
model OptionsDesk {
  id                 Int            @id @default(autoincrement())
  name               String
  status             String         @default("RUNNING") // RUNNING | PAUSED | ENDED
  cadence            String         @default("daily") // daily | hourly
  startingStakeCents Int            @default(5000000) // each arm's starting CAD cash (CA$50k, = the shadow stake)
  createdAt          DateTime       @default(now())
  startedAt          DateTime?
  endedAt            DateTime?
  entrants           DeskEntrant[]
}

// One player: CONTROL (stock-only) or TREATMENT (stock + buy-to-open options), same model.
model DeskEntrant {
  id        Int                @id @default(autoincrement())
  deskId    Int
  desk      OptionsDesk        @relation(fields: [deskId], references: [id], onDelete: Cascade)
  model     String // e.g. "claude-opus-4-8"
  arm       String // "control" | "treatment"
  dial      String             @default("BALANCED") // stock-side risk dial (DIALS in policy.ts)
  label     String // display name, e.g. "Opus · stock-only"
  cashCents Int // current CAD cash
  status    String             @default("ACTIVE") // ACTIVE | RETIRED
  createdAt DateTime           @default(now())
  positions DeskPosition[]
  trades    DeskTrade[]
  calls     DeskCall[]
  navSnaps  DeskNavSnapshot[]

  @@index([deskId])
}

// A position is polymorphic: a STOCK leg, or a CALL/PUT option leg. qty = shares (STOCK) or
// contracts (option, ×100 shares of exposure). avgCostCents/lastMarkCents are PER-SHARE
// (per-share premium for options). strike/expiry null for STOCK.
model DeskPosition {
  id            Int         @id @default(autoincrement())
  entrantId     Int
  entrant       DeskEntrant @relation(fields: [entrantId], references: [id], onDelete: Cascade)
  kind          String // STOCK | CALL | PUT
  underlying    String // bare ticker (the stock symbol for STOCK)
  strikeCents   Int? // option only
  expiry        String? // option only — YYYY-MM-DD
  qty           Int // shares (STOCK) or contracts (option)
  avgCostCents  Int // per-share cost (STOCK price / option premium)
  currency      String      @default("USD")
  lastMarkCents Int? // last per-share mark the engine wrote (options); stocks marked live
  openedAt      DateTime    @default(now())
  marks         DeskPositionMark[]

  @@index([entrantId])
}

// Per-session premium history for an OPEN option leg — powers the decay sparkline (docs §2 Phase 2-D).
// One row per option position per session; cascades away when the position closes/expires.
model DeskPositionMark {
  id         Int          @id @default(autoincrement())
  positionId Int
  position   DeskPosition @relation(fields: [positionId], references: [id], onDelete: Cascade)
  at         DateTime     @default(now())
  markCents  Int // per-share mark (premium) at this session

  @@index([positionId, at])
}

model DeskTrade {
  id               Int         @id @default(autoincrement())
  entrantId        Int
  entrant          DeskEntrant @relation(fields: [entrantId], references: [id], onDelete: Cascade)
  at               DateTime    @default(now())
  sessionAt        DateTime
  kind             String // STOCK | CALL | PUT
  underlying       String
  strikeCents      Int?
  expiry           String?
  side             String // BUY | SELL (stock) · BUY_TO_OPEN | SELL_TO_CLOSE | EXPIRE (option)
  qty              Int // shares or contracts
  priceCents       Int // per-share fill (premium for options); intrinsic at EXPIRE
  currency         String      @default("USD")
  commissionCents  Int // native
  realizedPnlCents Int? // CAD (close/expire only)

  @@index([entrantId])
}

// Per-session decision audit — every arm, every desk session (filled or not).
model DeskCall {
  id           Int         @id @default(autoincrement())
  entrantId    Int
  entrant      DeskEntrant @relation(fields: [entrantId], references: [id], onDelete: Cascade)
  sessionAt    DateTime
  action       String? // BUY | SELL | HOLD | NONE | BUY_OPTION | SELL_OPTION
  underlying   String? // stock symbol or option underlying
  right        String? // CALL | PUT (option calls)
  bias         String? // ATM | SLIGHTLY_OTM (option calls)
  strikeCents  Int? // resolved contract (option fills)
  expiry       String? // resolved contract (option fills)
  qty          Int? // shares or contracts
  confidence   Int?
  thesis       String?
  text         String // full reasoning
  filled       Boolean     @default(false)
  rejectReason String?

  @@index([entrantId])
  @@index([sessionAt])
}

model DeskNavSnapshot {
  id                Int         @id @default(autoincrement())
  entrantId         Int
  entrant           DeskEntrant @relation(fields: [entrantId], references: [id], onDelete: Cascade)
  at                DateTime    @default(now())
  navCadCents       Int
  cashCents         Int
  positionsCadCents Int
  optionsCadCents   Int         @default(0) // the option sleeve value (a subset of positions)

  @@index([entrantId, at])
}
