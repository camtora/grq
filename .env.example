# Copy to .env and fill in. chmod 600 .env
# House rule: single-quote any value containing a $ character.

POSTGRES_PASSWORD=
DATABASE_URL=postgresql://grq:<password>@db:5432/grq

# App-level member list (extends web/lib/users.ts; comma-separated)
GRQ_ALLOWED_EMAILS=cameron.tora@gmail.com,g.j.appleby@gmail.com

# Claude Max token for the agent (Phase 2) — mint with: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

TZ=America/Toronto

# --- Phase 3: IBKR paper (fill in when the paper account is ready; see
#     docs/IBKR-PHASE3.md). Keep BROKER=sim until the adapter is live-wired. ---
# BROKER=ibkr-paper
# IBEAM_ACCOUNT='paper-api-username'      # the dedicated secondary username
# IBEAM_PASSWORD='...'                    # single-quote — may contain a $
# IBKR_GATEWAY_URL=https://ibeam:5000     # the IBeam gateway (in-network)
# IBKR_ACCOUNT_ID=DU0000000               # paper account id (starts with DU)
# IBKR_FLEX_TOKEN='...'                   # Flex Web Service token (statements/NAV)
