<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Push Notifications (D53), GRQ Next target — DEBUG/development (Xcode-debug →
	     sandbox APNs). The distribution/Archive flow uses GRQNext-Release.entitlements
	     (production). The app reports which env minted each token so the server sends to
	     the matching gateway. See docs/PUSH-NOTIFICATIONS.md. -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
